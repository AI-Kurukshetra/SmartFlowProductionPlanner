# Copy to ".env.local" and fill values (never commit .env.local).
# Supabase: Dashboard → Project Settings → API
#
# NEXT_PUBLIC_SUPABASE_URL
#   Project URL, e.g. https://YOUR_REF.supabase.co
#
# NEXT_PUBLIC_SUPABASE_ANON_KEY
#   "anon" / "public" key (JWT starting with eyJ...) — safe for browser.
#   If you only see "Publishable key", use the anon JWT from the same API page.
#
# SUPABASE_SERVICE_ROLE_KEY
#   "service_role" secret — SERVER ONLY, bypasses RLS.
#   Needed for: admin invites, auto-creating missing app_users rows.
#   Never use NEXT_PUBLIC_ for this key.

NEXT_PUBLIC_SUPABASE_URL=https://xajplqhpmzwmjxusufej.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=paste-anon-jwt-from-dashboard-api-settings
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhhanBscWhwbXp3bWp4dXN1ZmVqIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MzQ2MTY0NiwiZXhwIjoyMDg5MDM3NjQ2fQ.w3xNDFKFnnxz_lZd8pUw-JTS_BA1z22EN7oUJtFPWKM

